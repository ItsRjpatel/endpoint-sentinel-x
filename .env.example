# ==========================================
# Endpoint Sentinel X - Root Environment Variables
# ==========================================

# Current active deployment environment (development, staging, production)
ENVIRONMENT=development

# Database connection details (Neon PostgreSQL compatible)
DATABASE_URL=postgresql+asyncpg://esx_admin:esx_password@localhost:5432/endpoint_sentinel

# Redis server URL
REDIS_URL=redis://localhost:6379/0

# Security (JWT secret should be generated randomly in production)
JWT_SECRET_KEY=super_secret_jwt_key_for_sentinel_x_platform_development_123!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Log configuration
LOG_LEVEL=info
